#!/usr/bin/env bash
# config/deployment.env — Per-deployment constants for baton-harness.
#
# Sourced by bin/run-daemon.sh at startup. Edit ONCE per deployment
# (e.g. when forking the harness for a new sandbox). After edit,
# bin/run-daemon.sh will source these values automatically and the
# operator no longer needs to export them by hand.
#
# Values left as empty placeholders will cause bin/run-daemon.sh to
# exit with a clear "edit config/deployment.env" error. This is
# intentional: a placeholder is structurally invalid and must be
# replaced before the daemon will start.

# ---- Sandbox repo identity (committed; visible in URLs — not sensitive)
export BH_REPO_OWNER=""    # GitHub org or user login
export BH_REPO_NAME=""     # Repository name (no owner prefix)

# ---- GitHub App identity (numeric IDs; visible in App settings URLs)
export BH_GITHUB_APP_ID=""               # GitHub App ID
export BH_GITHUB_APP_INSTALLATION_ID=""  # GitHub App installation ID

# ---- Structural mirrors — BWS_* twins reference the same identity.
#      Kept derived so the BH_* and BWS_* pairs cannot drift.
export BWS_APP_ID="${BH_GITHUB_APP_ID}"
export BWS_INSTALLATION_ID="${BH_GITHUB_APP_INSTALLATION_ID}"

# ---- Bitwarden Secrets vault — secret IDs (NOT secret values)
#      The IDs themselves are not sensitive. The values they unlock are.
#      Leave BWS_*_SECRET_ID empty to skip vault-fetch for that variable
#      and require the operator to export it (backward-compat mode).
export BWS_PEM_SECRET_ID=""                  # required — GitHub App PEM
export BWS_GH_TOKEN_SECRET_ID=""             # optional — GH_TOKEN fine-grained PAT
export BWS_HEARTBEAT_PING_URL_SECRET_ID=""   # optional — Slack webhook URL
