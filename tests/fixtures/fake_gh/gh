#!/usr/bin/env bash
# tests/fixtures/fake_gh/gh — recording shim for provision-ruleset.sh tests.
#
# Simulates the GitHub Rulesets REST API endpoints used by the script:
#   GET /app                                          (preflight)
#   GET /repos/<owner>/<repo>/collaborators?permission=admin
#                                                    (admin-role preflight)
#   GET /orgs/<owner>/custom-repository-roles        (admin-role override
#                                                    preflight)
#   GET /repos/<owner>/<repo>/rulesets                (LIST)
#   GET /repos/<owner>/<repo>/rulesets/<integer-id>   (BY-ID)
#   POST /repos/<owner>/<repo>/rulesets               (create)
#   PUT /repos/<owner>/<repo>/rulesets/<integer-id>   (update)
#
# Canned responses live in $BH_FAKE_GH_CANNED_DIR:
#   app_id.txt          — integer written as the "id" field for GET /app
#   app_unauthenticated — optional marker file (any content). When present,
#                         GET /app simulates the real API's behaviour for a
#                         PAT-authenticated caller: it is App-JWT-only, so a
#                         PAT gets a 401 and gh exits non-zero. Used to test
#                         issue #199 (soften the App-ID preflight for PAT auth).
#   app_no_id            — optional marker file (any content). When present,
#                         GET /app exits 0 (success) but returns a body with
#                         no "id" field (e.g. an authenticated caller whose
#                         token/response shape omits it). Used to test issue
#                         #199's no-.id gap (CodeRabbit follow-up): a
#                         successful-but-idless response must be treated the
#                         same as non-App auth, not as a mismatch.
#   app_transient_error — optional marker file (any content). When present,
#                         GET /app exits non-zero with a NON-401 stderr (e.g.
#                         "HTTP 503: Service unavailable"), simulating a
#                         transient/infra failure rather than a confirmed
#                         PAT-auth 401. Used to test the adversarial-review
#                         follow-up to issue #199 (PR #201): only a confirmed
#                         401 may soften into skip+proceed — any other
#                         non-zero exit from GET /app must hard-fail so an
#                         unconfirmed App ID is never silently written past.
#   app_stray_401        — optional marker file (any content). When present,
#                         GET /app exits non-zero with a stderr that contains
#                         the bare substring "401" (e.g. inside a correlation
#                         id) but NOT the substring "HTTP 401". Simulates an
#                         unrelated non-auth failure whose stderr happens to
#                         carry the digits "401" for an incidental reason
#                         (request id, byte count, etc). Used to test a
#                         CodeRabbit follow-up on PR #201: a bare `*"401"*`
#                         match in the preflight would false-trigger the
#                         soften-and-proceed path on this stderr; the
#                         preflight must require the specific "HTTP 401"
#                         substring to soften, and hard-fail here instead.
#   collaborators_admin.body
#                      — body for GET /collaborators?permission=admin
#   custom_roles.body   — optional body for GET /orgs/.../custom-repository-roles
#   list.body           — page 1 body for the LIST endpoint
#   list_page2.body     — optional page 2 body; when present, the shim
#                         concatenates it onto page 1 as a single FLAT
#                         array under --paginate (real `gh api --paginate`
#                         behaviour on an array endpoint — NOT the
#                         list-of-lists shape `--slurp` would produce;
#                         `--slurp` is a jq flag, not a `gh api` flag, and
#                         real `gh` rejects it — see the --slurp handling
#                         below)
#   byid_<id>.body      — body for GET /rulesets/<id>
#
# Every call is appended as a JSON line to $BH_FAKE_GH_LOG. Write calls
# (POST/PUT) additionally carry the raw request body (JSON-escaped) under
# the "body" field, so tests can assert on payload contents (e.g. that no
# "_comment" pseudo-comment key reaches the simulated API).

set -euo pipefail

_log() {
    printf '%s\n' "$1" >> "${BH_FAKE_GH_LOG}"
}

_strip_outer_brackets() {
    # Read a canned JSON-array file and return its inner content with the
    # leading "[" / trailing "]" (and surrounding whitespace) removed, so
    # callers can re-join several pages into one flat array. An empty-array
    # file ("[]") yields an empty string.
    local content
    content="$(cat "$1")"
    content="${content#"${content%%[![:space:]]*}"}"   # trim leading ws
    content="${content%"${content##*[![:space:]]}"}"   # trim trailing ws
    content="${content#\[}"
    content="${content%\]}"
    printf '%s' "${content}"
}

# Default to GET; override on --method / -X.
# Track --paginate (used by _lookup_id in provision-ruleset.sh).
_method="GET"
_paginate=0
_slurp=0
_args=("$@")
for i in "${!_args[@]}"; do
    case "${_args[$i]}" in
        --method | -X) _method="${_args[$((i + 1))]}" ;;
        --paginate)    _paginate=1 ;;
        --slurp)       _slurp=1 ;;
    esac
done

# --slurp is a jq flag, NOT a `gh api` flag. Real `gh` rejects it outright
# before making any request. Model that exactly so a caller that still
# passes --slurp (the pre-fix bug) fails the same way it would against the
# real API, instead of the shim silently emulating slurp-style output.
if [[ "${_slurp}" -eq 1 ]]; then
    printf 'gh: unknown flag: --slurp\n' >&2
    exit 1
fi

# Find the URL path (first arg matching a known prefix).
_url=""
for a in "${_args[@]}"; do
    case "${a}" in
        repos/* | /repos/* | orgs/* | /orgs/* | /app | app)
            _url="${a#/}"
            break
            ;;
    esac
done

# Classify the request into a logical endpoint.
_endpoint=""
_ruleset_id=""
_ruleset_name=""

if [[ "${_url}" == "app" ]]; then
    _endpoint="get_app"
elif [[ "${_url}" =~ ^orgs/[^/]+/custom-repository-roles$ ]]; then
    _endpoint="get_custom_roles"
elif [[ "${_url}" =~ ^repos/[^/]+/[^/]+/collaborators\?permission=admin$ ]]; then
    _endpoint="get_admin_collaborators"
elif [[ "${_url}" =~ ^repos/[^/]+/[^/]+/rulesets/([0-9]+)$ ]]; then
    _ruleset_id="${BASH_REMATCH[1]}"
    if [[ "${_method}" == "PUT" ]]; then
        _endpoint="put_update"
    else
        _endpoint="get_byid"
    fi
elif [[ "${_url}" =~ ^repos/[^/]+/[^/]+/rulesets$ ]]; then
    if [[ "${_method}" == "POST" ]]; then
        _endpoint="post_create"
    else
        _endpoint="get_list"
    fi
fi

# On write verbs, read stdin to extract the ruleset name for the call log.
if [[ "${_method}" == "POST" || "${_method}" == "PUT" ]]; then
    # Consume stdin; tolerate no stdin gracefully.
    _body="$(cat 2>/dev/null || true)"
    # Extract "name" value from JSON body using pure sed/bash — no python3.
    # Matches: "name": "some-value" (the only key we need).
    _ruleset_name="$(printf '%s' "${_body}" \
        | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
        | head -1 || true)"
fi

# Append structured call record to the log as a JSONL line.
# Pure bash printf — no python3 dependency.
_json_escape() {
    # Escape backslashes, double-quotes, tabs, and carriage-returns for JSON,
    # then collapse any embedded real newlines (write bodies are often
    # pretty-printed JSON, i.e. multi-line) into a literal "\n" so the
    # result is safe to embed as a single-line JSONL string value.
    printf '%s' "$1" \
        | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g; s/\r/\\r/g' \
        | sed ':a;N;$!ba;s/\n/\\n/g'
}
_record="$(printf '{"method":"%s","url":"%s","endpoint":"%s","ruleset_id":"%s","ruleset_name":"%s","body":"%s"}' \
    "$(_json_escape "${_method}")" \
    "$(_json_escape "${_url}")" \
    "$(_json_escape "${_endpoint}")" \
    "$(_json_escape "${_ruleset_id}")" \
    "$(_json_escape "${_ruleset_name}")" \
    "$(_json_escape "${_body:-}")")"
_log "${_record}"

# Serve canned responses.
case "${_endpoint}" in
    get_app)
        if [[ -f "${BH_FAKE_GH_CANNED_DIR}/app_unauthenticated" ]]; then
            # Simulate the real GET /app 401 a PAT-authenticated gh gets,
            # since that endpoint is App-JWT-only.
            printf 'gh: HTTP 401: Bad credentials (https://api.github.com/app)\n' >&2
            exit 1
        fi
        if [[ -f "${BH_FAKE_GH_CANNED_DIR}/app_transient_error" ]]; then
            # Simulate a non-auth GET /app failure (e.g. a 503 or network
            # blip) — NOT a 401 — so the script must distinguish this from
            # a confirmed PAT-auth failure and hard-fail rather than skip.
            printf 'gh: HTTP 503: Service unavailable (https://api.github.com/app)\n' >&2
            exit 1
        fi
        if [[ -f "${BH_FAKE_GH_CANNED_DIR}/app_stray_401" ]]; then
            # Simulate a non-auth GET /app failure whose stderr happens to
            # contain the bare substring "401" (e.g. inside a correlation
            # id) but NOT "HTTP 401". A preflight that matches on a bare
            # `*"401"*` substring would wrongly treat this as a confirmed
            # auth failure and soften+proceed; it must hard-fail instead.
            printf 'gh: could not resolve host api.github.com (correlation-id req-401aa)\n' >&2
            exit 1
        fi
        if [[ -f "${BH_FAKE_GH_CANNED_DIR}/app_no_id" ]]; then
            # Simulate a successful GET /app whose body has no "id" field.
            printf '{}\n'
            exit 0
        fi
        printf '{"id":%s}\n' "$(cat "${BH_FAKE_GH_CANNED_DIR}/app_id.txt")"
        exit 0
        ;;
    get_custom_roles)
        if [[ -f "${BH_FAKE_GH_CANNED_DIR}/custom_roles.body" ]]; then
            cat "${BH_FAKE_GH_CANNED_DIR}/custom_roles.body"
            exit 0
        fi
        printf '{"message":"Feature not available for the fake organization.","status":"404"}' >&2
        exit 1
        ;;
    get_admin_collaborators)
        cat "${BH_FAKE_GH_CANNED_DIR}/collaborators_admin.body"
        exit 0
        ;;
    get_list)
        # Real `gh api --paginate` on an array endpoint concatenates every
        # page into ONE FLAT array — it does not nest pages inside an outer
        # array. Strip each page's outer brackets and join the inner
        # entries with a comma so the emitted shape matches that flat
        # concatenation, not a list-of-lists.
        if [[ "${_paginate}" -eq 1 ]]; then
            _page1_inner="$(_strip_outer_brackets \
                "${BH_FAKE_GH_CANNED_DIR}/list.body")"
            _page2_inner=""
            if [[ -f "${BH_FAKE_GH_CANNED_DIR}/list_page2.body" ]]; then
                _page2_inner="$(_strip_outer_brackets \
                    "${BH_FAKE_GH_CANNED_DIR}/list_page2.body")"
            fi
            _joined=""
            if [[ -n "${_page1_inner}" && -n "${_page2_inner}" ]]; then
                _joined="${_page1_inner},${_page2_inner}"
            elif [[ -n "${_page1_inner}" ]]; then
                _joined="${_page1_inner}"
            elif [[ -n "${_page2_inner}" ]]; then
                _joined="${_page2_inner}"
            fi
            printf '[%s]\n' "${_joined}"
        else
            cat "${BH_FAKE_GH_CANNED_DIR}/list.body"
        fi
        exit 0
        ;;
    get_byid)
        _body_file="${BH_FAKE_GH_CANNED_DIR}/byid_${_ruleset_id}.body"
        if [[ -f "${_body_file}" ]]; then
            cat "${_body_file}"
            exit 0
        fi
        printf 'gh: Not Found (HTTP 404)\n' >&2
        exit 1
        ;;
    post_create | put_update)
        # Write operations: echo a minimal success body.
        printf '{"id":1,"name":"%s"}\n' "${_ruleset_name}"
        exit 0
        ;;
    *)
        printf 'gh: unknown endpoint for url=%s method=%s\n' \
            "${_url}" "${_method}" >&2
        exit 1
        ;;
esac
