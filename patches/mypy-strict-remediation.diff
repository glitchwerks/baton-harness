# NOTE (added by #224, does not modify the diff below — D3: patches/ is frozen as
# historical record, hunks are not rewritten): the `module = "baton_harness.vendor.*"`
# wildcard override introduced by this diff was replaced in #224 Phase 1 with an
# explicit per-file module list in `pyproject.toml`'s `[[tool.mypy.overrides]]` block,
# narrowed further as each phase cleans and un-excludes a file. See
# `src/baton_harness/vendor/symphony/VENDORING.md` § "mypy strict-remediation" and
# `docs/superpowers/plans/2026-07-14-assimilate-vendored-symphony-224.md`. Do not use
# the wildcard shown below as a re-vendor reference — read the live `pyproject.toml`
# instead.
diff --git a/pyproject.toml b/pyproject.toml
index b39b623..650c1d0 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -11,10 +11,14 @@ name = "baton-harness"
 version = "0.1.0"
 description = "Policy and tooling layer wrapping Baton for autonomous Claude Code agent runs."
 requires-python = ">=3.10"
-# Runtime dependencies: none. All three hooks shell out to git/gh via
-# subprocess and parse JSON with the stdlib json module. Baton itself is
-# pip-installed in the container environment (harness-design.md §Decision).
-dependencies = []
+# Runtime dependencies: pyyaml and jinja2 are required by the vendored
+# symphony package (config.py uses yaml, prompt.py uses jinja2).
+# watchfiles is intentionally excluded — the symphony poller is dropped
+# in favour of the custom always-on daemon (CLAUDE.md § Upstream dependency).
+dependencies = [
+    "pyyaml>=6.0",
+    "jinja2>=3.1",
+]
 
 [project.optional-dependencies]
 dev = [
@@ -86,6 +90,15 @@ warn_unused_ignores = true
 warn_return_any = true
 show_error_codes = true
 
+# mypy: ignore all errors in the vendored third-party tree.
+# Full annotation of the vendored symphony source is deferred; the daemon
+# calls into it via a narrow typed seam in chain/ only.
+# Recorded as patches/mypy-strict-remediation.diff (kept separate from
+# the behaviour patches VP-1, VP-2, etc.).
+[[tool.mypy.overrides]]
+module = "baton_harness.vendor.*"
+ignore_errors = true
+
 [tool.pytest.ini_options]
 testpaths = ["tests"]
 addopts = "-v"
